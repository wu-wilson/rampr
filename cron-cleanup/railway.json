{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "watchPatterns": ["cron-cleanup/**"]
  },
  "deploy": {
    "startCommand": "npm start",
    "cronSchedule": "0 6 * * 0",
    "restartPolicyType": "NEVER"
  }
}
