# Postgres connection string for the rampr database.
DATABASE_URL=postgresql://localhost:5432/rampr

# Maximum number of company feeds fetched concurrently per run.
POLL_CONCURRENCY=4

# Per-request abort timeout in milliseconds for ATS feed fetches.
REQUEST_TIMEOUT_MS=10000

# User-Agent sent to public ATS endpoints, identifying the poller.
USER_AGENT=rampr (+https://github.com/wu-wilson/rampr)
