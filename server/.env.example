# Port the API listens on.
PORT=3001

# Postgres connection string (the rampr database).
DATABASE_URL=postgresql://localhost:5432/rampr

# CORS allowlist — comma-separated origins, or * to reflect any origin (dev).
ALLOWED_ORIGINS=*

# Per-IP read rate limit across the /api surface, per hour.
READ_RATE_LIMIT_PER_HOUR=600
